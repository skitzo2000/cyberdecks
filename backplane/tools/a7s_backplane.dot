graph a7s_backplane {
  rankdir=LR; splines=true; overlap=false; nodesep=0.28; ranksep=1.4;
  bgcolor="white";
  fontname="DejaVu Sans"; fontsize=22; labelloc="t";
  label="A7S Cyberdeck Backplane — connectivity diagram\n(generated from a7s_backplane_skidl.py — the schematic source of truth)";
  node [fontname="DejaVu Sans"];
  edge [fontname="DejaVu Sans", fontsize=8];
  subgraph cluster_0 {
    label="HOST (A7S)"; style="rounded,filled"; fillcolor="#f4f6f8"; color="#b0b8c0"; fontsize=16;
    "J1" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="A7S host header\n2x15 (Conn_02x15)"];
    "J2" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="A7S host header\n1x15 (Conn_01x15)"];
  }
  subgraph cluster_1 {
    label="POWER"; style="rounded,filled"; fillcolor="#f4f6f8"; color="#b0b8c0"; fontsize=16;
    "F1" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Polyfuse F1\nMF-R050 0.5A (5V)"];
    "F2" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Polyfuse F2\nMF-R050 0.5A (3V3)"];
    "C8" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="C8 0.1uF\nradio1 decouple"];
    "C9" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="C9 0.1uF\nradio2 decouple"];
  }
  subgraph cluster_2 {
    label="DISPLAY"; style="rounded,filled"; fillcolor="#f4f6f8"; color="#b0b8c0"; fontsize=16;
    "J3" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="TFT 2.8\" (J3)\nConn_01x14"];
  }
  subgraph cluster_3 {
    label="RADIOS"; style="rounded,filled"; fillcolor="#f4f6f8"; color="#b0b8c0"; fontsize=16;
    "J5" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Radio 1 (J5)\n2x04 socket"];
    "J6" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Radio 2 (J6)\n2x04 socket"];
    "J5b" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="J5b\nradio1 aux pin"];
    "J6b" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="J6b\nradio2 aux pin"];
  }
  subgraph cluster_4 {
    label="CO-PROCESSOR + INPUTS"; style="rounded,filled"; fillcolor="#f4f6f8"; color="#b0b8c0"; fontsize=16;
    "A1" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="RP2040-Zero (A1)\nco-processor"];
    "SW1" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="SW1 button"];
    "SW2" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="SW2 button"];
    "SW3" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="SW3 button"];
    "SW4" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="SW4 button"];
    "J8" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Joystick (J8)\nConn_01x05"];
    "J10" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Encoder (J10)\nConn_01x04"];
    "J11" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Buttons 5/6 (J11)\nConn_01x03"];
  }
  subgraph cluster_5 {
    label="EXPANSION / CONSOLE"; style="rounded,filled"; fillcolor="#f4f6f8"; color="#b0b8c0"; fontsize=16;
    "J12" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="Flipper GPIO (J12)\n1x18 header"];
    "TP1" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="TP1\nconsole TX"];
    "TP2" [shape=box, style="filled,rounded", fillcolor="#dfe7ef", color="#34495e", label="TP2\nconsole RX"];
  }
